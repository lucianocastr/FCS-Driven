<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
	"http://www.w3.org/TR/html4/loose.dtd">
<html>
<!--<![-->
	<head>
		<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" >
		<meta http-equiv="content-type" content="text/html; charset=ISO-8859-1" >
		<meta http-equiv="cache-control" content="no-transform">
		<link href="/base.css" rel="stylesheet" type="text/css">
		<title>Downlink&nbsp;Spectrum</title>
		<script language="JavaScript" type="text/javascript" src="/base.js"></script>
		<script language="JavaScript" type="text/javascript" src="/config.js"></script>
		<script language="JavaScript" type="text/javascript" src="/monitor.js"></script>
		<script language="JavaScript" type="text/javascript" src="/objfactory.js"></script>
		<script language="JavaScript" type="text/javascript" src="/spectrum.js"></script>
	</head>
	<body onload="onloadInit();" onunload="stop_loading_spectrum();">
		<div class="spectbox">
			<div class="headbox"><table><tbody><tr>
				<td class="small">DOWNLINK&nbsp;SPECTRUM</td>
				<td class="ttitle" style="width:100%;text-align:center;">OUTPUT</td>
				<td class="small" style="min-width:100px;" id="outSpectTip"></td>
			</tr></tbody></table></div>
			<div id="outContentbox" class="spectContentBox" style="height:240px;width:100%"></div>
		</div><br>
		<div class="spectbox">
			<div class="headbox"><table><tbody><tr>
				<td class="small">DOWNLINK&nbsp;SPECTRUM</td>
				<td class="ttitle" style="width:100%;text-align:center;">INPUT</td>
				<td class="small" style="min-width:100px;" id="inSpectTip"></td>
			</tr></tbody></table></div>
			<div id="inContentbox" class="spectContentBox" style="height:240px;width:100%"></div>
		</div>
		<form id="spectrum_req" name="spectrum_req" action="/spectrum.zhtml" METHOD="POST" accept-charset="ISO-8859-1">
			<input type="hidden" id="spect_req" name="spect_req">
			<input type="hidden" id="conf_req" name="conf_req">
			<input type="hidden" id="fact_req" name="fact_req">
			<input type="hidden" id="spect_band" name="spect_band">
		</form>
	</body>
</html>
