function Tags(){this.TAGLENDEVICE=30,this.MAXDEVICES=9,this.TAGLEN=this.TAGLENDEVICE*this.MAXDEVICES,this.tag="",this.tagDevices=[];for(var t=0;t<this.MAXDEVICES;t++)this.tagDevices.push("");this.parse=function(t){try{this.tag="";for(var s=0;s<t.length&&s<2*this.TAGLEN;s+=2){var i=t.substr(s,2),r=parseInt(i,16);isNaN(r)?this.tag+="&nbsp;":this.tag+=String.fromCharCode(r)}this.splitTags()}catch(t){}},this.parseRawText=function(t){try{this.tag="";for(var s=0;s<t.length&&s<this.TAGLEN;s++){var i=t.charCodeAt(s);this.tag+=32<=i&&i<127?t[s]:" "}this.splitTags()}catch(t){}},this.splitTags=function(){for(var t=0;t<this.MAXDEVICES;t++)this.tagDevices[t]=this.tag.substr(t*this.TAGLENDEVICE,this.TAGLENDEVICE)},this.render=function(){for(var t=0;t<this.MAXDEVICES;t++)try{setTag(this.tagDevices[t],t)}catch(t){}},this.format=function(t){t=t.trim();for(var s=0;s<this.TAGLEN;++s)t+=" ";t=t.slice(0,this.TAGLEN);for(var i="",s=0;s<this.TAGLEN;++s){var r=t.charCodeAt(s),h=isNaN(r)?"20":"00"+r.toString(16);i+=h.slice(-2)}return i},this.formatRowText=function(t){t=t.trim();for(var s=0;s<this.TAGLENDEVICE;++s)t+=" ";return t=t.slice(0,this.TAGLENDEVICE),correctASCIIOnlyText(t)}}function SerialNrRemotes(){this.SERIALLENDEVICE=15,this.MAXDEVICES=9,this.SERIALLEN=this.SERIALLENDEVICE*this.MAXDEVICES,this.serialNr="",this.serialNrDevices=[];for(var t=0;t<this.MAXDEVICES;t++)this.serialNrDevices.push("");this.parse=function(t){try{this.serialNr="";for(var s=0;s<t.length&&s<2*this.SERIALLEN;s+=2){var i=t.substr(s,2),r=parseInt(i,16);isNaN(r)?this.serialNr+="&nbsp;":this.serialNr+=String.fromCharCode(r)}this.splitSerials()}catch(t){}},this.parseRawText=function(t){try{this.serialNr="";for(var s=0;s<t.length&&s<this.SERIALLEN;s++){var i=t.charCodeAt(s);this.serialNr+=32<=i&&i<127?t[s]:" "}this.splitSerials()}catch(t){}},this.splitSerials=function(){for(var t=0;t<this.MAXDEVICES;t++)this.serialNrDevices[t]=this.serialNr.substr(t*this.SERIALLENDEVICE,this.SERIALLENDEVICE)},this.render=function(){for(var t=1;t<this.MAXDEVICES;t++)try{setSerialNr(this.serialNrDevices[t],t)}catch(t){}}}function VersionRemotes(){this.VERSIONLENMASTER=8,this.VERSIONLENREMOTE=4,this.MAXDEVICES=9,this.VERSIONLEN=this.VERSIONLENMASTER+this.VERSIONLENREMOTE*(this.MAXDEVICES-1),this.version="",this.versionDevices=[];for(var t=0;t<this.MAXDEVICES;t++)this.versionDevices.push([]);this.parse=function(t){this.version="";for(var s=0,i=0,r=0;r<t.length&&r<2*this.VERSIONLEN;r+=2){var h=t.substr(r,2);try{num=parseInt(h,16)}catch(t){num=0}this.versionDevices[s].push(num),0==s?++i>=this.VERSIONLENMASTER&&(i=0,s++):++i>=this.VERSIONLENREMOTE&&(i=0,s++)}},this.render=function(t){for(var s=1;s<this.MAXDEVICES;s++){for(var i="",r=0;r<this.VERSIONLENREMOTE;r++)0<r&&(i+="."),i+=this.versionDevices[s][r];"0.0.0.0"==i&&(i="");try{setVersion(i,s)}catch(t){}}}}