<!--
function check_result(){"undefined"==typeof countPass&&(countPass=0);try{var e=xmlreq();e.onreadystatechange=function(e){if(4==this.readyState)if(200===this.status){var t=parseInt(this.responseText);if(isNaN(t))showResult("#d03030","Unknown");else switch(t<0&&(t=-t),t){case 0:showResult("#30d030","DONE");break;case 1:showResult("#e03030","ERROR: Current Password");break;case 2:showResult("#e03030","ERROR: Password Confirm");break;case 3:showResult("#e03030","FAIL: Authorization");break;default:showResult("#e03030","ERROR")}}else showResult("#e03030","Network Error")},e.onerror=function(e){showResult("#e03030","Network Error")},e.ontimeout=function(e){showResult("#e03030","Network Error")},countPass=0,Date.now=Date.now||function(){return+new Date},e.open("GET","/result.shtml?co="+Date.now(),!0),e.timeout=1e4,e.send(null),e=null}catch(e){}}function showResult(e,t){document.getElementById("textMsg").style.color=e,document.getElementById("textMsg").innerHTML=t,setTimeout(function(){window.location.replace("/password.zhtml")},1500)}
// -->