<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
	"http://www.w3.org/TR/html4/loose.dtd">
<html>
<!--<![-->
	<head>
		<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" >
		<meta http-equiv="content-type" content="text/html; charset=ISO-8859-1" >
		<meta http-equiv="cache-control" content="no-transform">
		<link id="cssfile" href="/base.css" rel="stylesheet" type="text/css">
		<script language="JavaScript" type="text/javascript" src="/base.js"></script>
		<script language="JavaScript" type="text/javascript" src="/tags.js"></script>
		<script language="JavaScript" type="text/javascript" src="/objfactory.js"></script>
		<script language="JavaScript" type="text/javascript" src="/config.js"></script>
		<script language="JavaScript" type="text/javascript" src="/file.js"></script>
		<script language="JavaScript" type="text/javascript" src="/navi.js"></script>
		<script language="JavaScript" type="text/javascript" src="/version.js"></script>		
		<script language="JavaScript" type="text/javascript">
		var serialNr = "--";
		function onloadInit() {
			createForm();
			try {
				var el = window.parent.navi.document.getElementById("sernrBox");
				if (el)
					serialNr = el.innerHTML;
				document.getElementById("sernrEntry").value = serialNr.trim();
			} catch (err) { }
			guiBlocked(false);
		}
		function reloadData(){
			try {
				showResultIcon(ERR_PENDING);
				guiBlocked(true);
				frameReq();
				// document.getElementById("sernrEntry").value = serialNr.trim();
			} catch (err) { }
		}
		function createForm() {
			var rootNode = document.getElementById("rootNode");
			remove_children(rootNode);
			var row = document.createElement("tr");
			rootNode.appendChild(row);
			row.id = "remote";
			var header = document.createElement("th");
			row.appendChild(header);
			header.style.width = "100px";
			header.style.textAlign = "left";
			header.innerHTML = "SERIAL&nbsp;NUMBER";
			var cell = document.createElement("td");
			row.appendChild(cell);
			var sernr = document.createElement("input");
			sernr.type = "text";
			cell.appendChild(sernr);
			sernr.id = "sernrEntry";
			sernr.className = "tag";
			sernr.size = "15";
			sernr.maxLength = "15";
			sernr.onkeypress = function(ev) {
				ev = ev || window.event;
				if (ev.keyCode == 13)
					return false;
			}
		}
		var countConf;
		function submitform() {
			guiBlocked(true);
			showResultIcon(ERR_PENDING);
			var str = '';
			var str = document.getElementById("sernrEntry").value;
			var SERLEN = 15;
			str = str.trim();
			for (var j = 0; j < SERLEN; ++j)
				str += ' ';
			str = str.slice(0, SERLEN);
			try {
				var xhr = xmlreq();
				xhr.onreadystatechange  = function(ev) {
					if (this.readyState==4) {
						if (this.status === 200) {
							countConf = 0;
							serialNr = str;
							setTimeout(function() { check_result(); }, 100);
						} else {
							showResultIcon(ERR_FAIL);
							setTimeout(function() { xhrOnEnd(); }, 1500);
						}
					}
				}
				xhr.onerror = function(ev) {
					showResultIcon(ERR_FAIL);
					setTimeout(function() { xhrOnEnd(); }, 1500);
				}
				xhr.ontimeout = function(ev) {
					showResultIcon(ERR_FAIL);
					setTimeout(function() { xhrOnEnd(); }, 1500);
				}
				xhr.open("POST", "/factory/sern.zhtml", true);
				xhr.timeout = 5000;
				xhrOnStart();
				xhr.send("ctl_sernr_str="+str);
				xhr = null;
			} catch (err) {
				showResultIcon(ERR_FAIL);
				setTimeout(function() { xhrOnEnd(); }, 1500);
			}
		}
		function xhrOnStart() {
			cursorWait();
		}
		function xhrOnEnd() {
			cursorClear();
			showResultIcon(ERR_NONE);
			guiBlocked(false);
		}
		function check_result() {
			if (typeof countConf === "undefined")
				countConf = 0;
			try {
				var xhr = xmlreq();
				xhr.onreadystatechange  = function(ev) {
					if (this.readyState==4) {
						var error;
						if (this.status === 200) {
							error = parseInt(this.responseText);
							if (error != ERR_OK && error != ERR_FAIL) {
								if (++countConf < 25) {
									setTimeout(function() { check_result(); }, 1000);
									return;
								} else
									error = ERR_FAIL;
							}
						} else {
							error = ERR_FAIL;
						}
						if (error == ERR_OK) {
							reloadData();
							try {
								var el = window.parent.navi.document.getElementById("sernrBox");
								if (el)
									el.innerHTML = serialNr;
							} catch (err) { }
						}
						showResultIcon(error);
						setTimeout(function() { xhrOnEnd(); }, 1500);
					}
				}
				xhr.onerror = function(ev) {
					showResultIcon(ERR_FAIL);
					setTimeout(function() { xhrOnEnd(); }, 1500);
				}
				xhr.ontimeout = function(ev) {
					showResultIcon(ERR_FAIL);
					setTimeout(function() { xhrOnEnd(); }, 1500);
				}
				Date.now = Date.now || function() { return +new Date; }; 
				xhr.open("GET", "/result.shtml?co="+Date.now(), true);
				xhr.timeout = 5000;
				xhr.send(null);
				xhr = null;
			} catch (err) {}
		}
		function frameReq() {
			try {
				var xhr = xmlreq();
				xhr.onreadystatechange  = function(ev) {
					if (this.readyState === 4 && this.status === 200) {
						setTimeout(function() { load_sernr(); }, 1000);
					}
				}
				xhr.onerror = function(ev) {
					setTimeout(function() { frameReq(); }, 2000);
				}
				xhr.ontimeout = function(ev) {
					setTimeout(function() { frameReq(); }, 2000);
				}
				xhr.open("POST", "/factory/sern.zhtml", true);
				xhr.timeout = 10000;
				xhr.send("sernr_req="+1);
				xhr = null;
			} catch (err) {}
		}
		function load_sernr() {
			try {
				var xhr = xmlreq();
				xhr.onreadystatechange  = function(ev) {
					if (this.readyState === 4 && this.status === 200) {
						serialNr = this.responseText;
						window.parent.navi.serNrFrame = this.responseText;
						var el = window.parent.navi.document.getElementById("sernrBox");
						if (el) {
							el.innerHTML = serialNr.trim();
						}
						el = document.getElementById("sernrEntry");
						if (el) {
							el.value = serialNr.trim();
						}
						initFormChangeCheck();
						xhrOnEnd();
					}
				}
				Date.now = Date.now || function() { return +new Date; }; 
				xhr.open("GET", "/update_sernr.shtml?co="+Date.now(), true);
				xhr.timeout = 5000;
				xhr.send(null);
				xhr = null;
			} catch (err) { }
		}
		</script>
		<title>Fiplex Control Software</title>
	</head>
	<body onload="onloadInit();">
		<form id="sernr_form" name="sernr_form" action="/factory/sern.zhtml" METHOD="POST">
			<input type="hidden" id="ctl_sernr_str" name="ctl_sernr_str" value="" size="100" >
			<input type="hidden" id="sernr_req" name="sernr_req">
			<h1>SERIAL NUMBER</h1><br/>
			<table><tbody id="rootNode">
			</tbody></table>
			</br>
		</form>
	</body>
</html>
