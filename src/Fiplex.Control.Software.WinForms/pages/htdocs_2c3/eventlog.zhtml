<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
	"http://www.w3.org/TR/html4/loose.dtd">
<html>
<!--<![-->
	<head>
		<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" >
		<meta http-equiv="content-type" content="text/html; charset=UTF-8" >
		<meta http-equiv="cache-control" content="no-transform">
		<link id="cssfile" href="/a/c/base.css" rel="stylesheet" type="text/css">
		<link href="/a/c/meter.css" rel="stylesheet" type="text/css">
		<script language="JavaScript" type="text/javascript" src="/a/j/base.js"></script>
		<script language="JavaScript" type="text/javascript" src="/a/j/objfactory.js"></script>
		<script language="JavaScript" type="text/javascript" src="/a/j/config.js"></script>
		<script language="JavaScript" type="text/javascript" src="/a/j/file.js"></script>
		<script language="JavaScript" type="text/javascript" src="/a/j/navi.js"></script>		
		<style type="text/css">
			table.logtab {
				border-collapse: collapse;
				text-align: center;
			}
			th.logtab {
				font-size: 20px;
			}
			td.controls {
				margin-right: auto;
				margin-left: auto;
			}
			input.controls {
				min-width: 60pt;
				font-weight: bold;
				background-color: #EEEEEE;
			}
			#logdata {
				min-width: 700pt;
				min-height: 370pt;
				padding: 10px 10px 10px 10px;
			}
			#refreshC {

			}
		</style>
		<script language="JavaScript" type="text/javascript" src="/a/j/lang_en.js"></script>
		<script language="JavaScript" type="text/javascript" src="/a/j/alarmlog.js"></script>
		<script language="JavaScript" type="text/javascript" src="/a/j/eventlog.js"></script>
		<script language="JavaScript" type="text/javascript" src="/a/j/tags.js"></script>
		<script language="JavaScript" type="text/javascript" src="/a/j/version.js"></script>
		<title>Fiplex Control Software</title>
	</head>

	<body class="m" onload="onloadInit();" >
		&nbsp;<br>
		<form id="log_form" name="log_form" action="/eventlog.zhtml" method="POST" accept-charset="ISO-8859-1">
			<div id="page">
				<table class="logtab">
					<thead>
						<tr>
							<th class="tag" colspan="3">ALARM&nbsp;LOG</th>
						</tr>
					</thead>
					<tbody>
						<tr style="height:5px;"></tr>
						<tr>
							<td class="controls">
								<input type="button" name="REFRESH" value="REFRESH" id="refreshB" class="controls">
							</td>
							<td class="controls">
								<input type="button" name="CLEAR" value="CLEAR" id="clearB" class="controls">
							</td>
							<td class="controls">
								<input type="button" name="SAVE" value="SAVE" id="saveB" class="controls">
							</td>
						</tr>
						<tr>
							<td  colspan="3">
								<textarea id="logdata" name="logdata" readonly="readonly" cols="100"></textarea>
							</td>
						</tr>
					</tbody>
				</table>
			</div>
			<input type="hidden" id="log_event_str" name="log_event_str">
			<input type="hidden" id="log_req" name="log_req">
		</form>
		&nbsp;<br>
	</body>
</html>
