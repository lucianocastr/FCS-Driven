body{margin:0;padding:0;font-size:13px;font-family:Arial,Helvetica,sans-serif;color:#fff;background-color:#fff}.clear:after{content:".";display:block;height:0;clear:both;visibility:hidden;line-height:0}.clear{display:block;width:100%;clear:both}html[xmlns] .clear{display:block}* html .clear{height:1%}.fl_left{float:left}.fl_right{float:right}address,aside,figcaption,figure,footer,header,nav{display:block;margin:0;padding:0;background-color:#004a98}q{display:block;padding:0 10px 8px 10px;color:#979797;background-color:#ececec;font-style:italic;line-height:normal}q:before{content:'“ ';font-size:26px}q:after{content:' „';font-size:26px;line-height:0}div.wrapper{display:block;width:100%;margin:0;padding:0;text-align:left}.row1,.row1 a{color:#fff;background-color:#004a98}.row2{color:#004a98;background-color:#fff}.row2 a{color:#4b4b4b;text-decoration:none}.row3,.row3 a{color:#fff;background-color:#fff}#container,#footer,#header{display:block;margin:0 auto;width:960px}nav ul{margin:0;padding:0;list-style:none}h1,h2,h4,h5,h6{margin:0;padding:0;font-size:25px;font-weight:700;font-style:normal;line-height:normal}h3{font-family:arial;font-size:12px;font-weight:700;color:#000}#header,#header a{color:#c0bab6;background-color:#004a98}#header #hgroup{float:left}#header #hgroup h1{font-size:36px}#header #hgroup h2{font-size:13px}#header nav{float:right;padding:20px 0}#header nav ul{margin-top:60px}#header nav li{display:inline;margin-right:100px;color:#fff;font-size:30px;font-weight:700}#header nav li.last{margin-right:0}#header nav a{color:#c0bab6}#header nav a:hover{color:#f90}#container{padding:30px 0}#container section{margin:0 0 30px 0}#container section.last{margin:0}#container .more{text-align:right;text-transform:uppercase;font-size:smaller;font-weight:700}#footer p{margin:0;padding:20px 0;padding-left:30px;padding-right:90px}table{display:table;border-spacing:0}.contentcell{background-color:#e6e6e6;vertical-align:top;margin-left:0;margin-right:0}.thdrht{white-space:nowrap;padding-left:12px;text-align:left}.tabledatos{border-collapse:collapse;border-spacing:10;font-size:12px;text-align:left;margin:0 0 2em 0;width:100%}input.number{display:block;margin-left:auto;margin-right:auto;text-align:right;font-size:9pt}.tabletd{color:#484848;background-color:#f5f5f5;text-align:center;font-size:15px;font-weight:700;border-right:3px solid #cfcfcf;border-bottom:3px solid #cfcfcf;padding:10px}.tdBlack{color:#000;font-weight:700;text-align:center;padding-left:20px;padding-right:20px}.rht{text-align:right;padding-right:10px}.tdBlackl{color:#000;font-weight:700;text-align:left;padding-left:10px;padding-right:20px}.tdBlue{padding-left:10px;padding-right:10px;text-align:center}.tabledatos tbody tr:nth-child(2n+1){background-color:rgba(144,144,144,.045)}.tabledatos td{padding:.75em .75em;text-align:left}.tabledatos tbody tr{border-left:0;border-right:0}.content .tabval{font-family:arial;color:#802000;font-weight:700;font-size:10pt;white-space:nowrap}.bordederecho{border-radius:0 8px 8px 0;-moz-border-radius:0 8px 8px 0;-webkit-border-radius:0 8px 8px 0;border:0 solid #000;border-right:3px solid #cfcfcf;text-align:center;border-bottom:3px solid #cfcfcf}.bordeizq{border-radius:8px 0 0 8px;-moz-border-radius:8px 0 0 8px;-webkit-border-radius:8px 0 0 8px;border:0 solid #000}.contenttable{width:100%;border-spacing:6px;border-collapse:separate;margin-left:0;margin-right:0}.contenttable td{text-align:center}.divdashboard{padding-left:30px;padding-right:90px}.padddingvolver{padding-right:90px}.titulopag{margin:0;padding:0;font-size:25px;font-weight:700;font-style:normal;line-height:normal}input,select,textarea{color:#555}input,select,textarea{font-family:Arial,Helvetica,sans-serif;font-size:10pt;font-weight:300;letter-spacing:.09em}progress{-webkit-appearance:none;-moz-appearance:none;appearance:none;border:none;width:150px}.prgamarilllo{color:#ff0;background-color:#ff0}.prgrojo{color:red;background-color:red}.prgverde{color:green;background-color:green}.error{color:red;font-weight:700}.textonegro{color:#000;font-weight:700}.btnazul{background-color:#004a98;border:none;color:#fff;padding:5px 10px;text-align:center;text-decoration:none;display:inline-block;font-size:13px;margin:4px 2px;cursor:pointer;border-radius:7px 7px 7px 7px;-moz-border-radius:7px 7px 7px 7px;-webkit-border-radius:7px 7px 7px 7px;border:0 solid #004a98}.btnnaranja{background-color:#f39323;border:none;color:#fff;padding:5px 10px;text-align:center;text-decoration:none;display:inline-block;font-size:13px;margin:4px 2px;cursor:pointer;border-radius:7px 7px 7px 7px;-moz-border-radius:7px 7px 7px 7px;-webkit-border-radius:7px 7px 7px 7px;border:0 solid #004a98}canvas{background:#000;display:block;margin:0 auto}.divprogress{width:150px}.progress-bar{width:100%;background-color:#e0e0e0;padding:1px;border-radius:1px;box-shadow:inset 0 1px 3px rgba(0,0,0,.2)}.progress-bar-fill{display:block;height:12px;border-radius:1px;transition:width .5s ease-in-out}.ctrltempmarco{background-color:rgba(144,144,144,.045);border:0;color:#004a98;font-weight:700;text-align:right}.confirm700{background-color:#ffa754;border-radius:7px 7px 7px 7px;-moz-border-radius:7px 7px 7px 7px;-webkit-border-radius:7px 7px 7px 7px;border:0 solid #004a98;position:fixed;width:250px;left:50%;margin-left:-100px;padding:6px 8px 8px;box-sizing:border-box;text-align:center;color:#000;font-weight:700}.colornaranajafiplex{color:#f39323}.colorazulfiplex{color:#004a98}.divalertlic{border:3px solid;border-top-color:red;border-right-color:red;border-bottom-color:red;border-left-color:red;border-style:double;font-size:18pt;color:red;text-align:center}.divalertinfo{border:3px solid;border-top-color:4a98;border-right-color:4a98;border-bottom-color:4a98;border-left-color:4a98;font-size:11pt;color:#004a98}input[type=text]::-ms-clear{display:none}