body{margin-top:1px;margin-bottom:0}.spectbox{width:801px;outline:thin solid #db5902;margin-top:0;margin-bottom:0;margin-left:50px;display:inline-block}.spectContentBox{height:480px;width:801px;background-color:#101010}.stitlein{font-weight:700;color:#e0e030;text-shadow:1px 1px #000;font-size:1.875em}.stitleout{font-weight:700;color:#60ff60;text-shadow:1px 1px #000;font-size:1.875em}.stitle{font-family:verdana,helvetica;height:17px;background-color:#d8d8d8;color:#db5902;vertical-align:middle;text-align:center;white-space:nowrap;font-size:10px}.spectnormalbar{min-width:1px;outline:0;position:absolute;bottom:0;background-color:#101070;opacity:.8;z-index:1002}.spectnormalbar:hover{outline:thin solid red}.spectmarkbar{width:1px;outline:0;position:absolute;top:1px;background-color:#5050b0;z-index:1001}.graphxdiv{background-image:url(/i/strl.gif);background-repeat:repeat-x;position:absolute;left:0;width:100%;height:1px;text-align:left;z-index:999}.graphydiv{background-image:url(/i/strv.gif);background-repeat:repeat-y;position:absolute;top:0;width:1px;height:100%;z-index:999}.spectleft{float:left;margin-top:10px;margin-bottom:10px;display:table-cell;vertical-align:middle;height:400px;background-color:#d8d8d8}.spectright{float:right;margin-top:10px;margin-bottom:10px;display:table-cell;vertical-align:middle;height:400px;background-color:#d8d8d8}