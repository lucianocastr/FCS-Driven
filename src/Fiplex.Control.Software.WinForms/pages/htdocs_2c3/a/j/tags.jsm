function Tags(){this.TAGLEN=730,this.tag="",this.parse=function(t){try{this.tag="";for(var a=0;a<t.length&&a<2*this.TAGLEN;a+=2){var i=t.substr(a,2),i=parseInt(i,16);isNaN(i)?this.tag+=" ":this.tag+=String.fromCharCode(i)}}catch(t){}},this.parseRawText=function(t){try{this.tag="";for(var a=0;a<t.length&&a<this.TAGLEN;a++){var i=t.charCodeAt(a);this.tag+=32<=i&&i<127?t[a]:" "}}catch(t){}},this.render=function(){try{setTag(this.tag)}catch(t){}},this.getTag=function(){return this.tag},this.format=function(t){for(var a=0;a<this.TAGLEN;++a)t+=" ";t=t.slice(0,this.TAGLEN);for(var i="",a=0;a<this.TAGLEN;++a){var r=t.charCodeAt(a),r=isNaN(r)?"20":"00"+r.toString(16);i+=r.slice(-2)}return i}}