<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
	"http://www.w3.org/TR/html4/loose.dtd">
<html>
<!--<![-->
	<head>
		<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" >
		<meta http-equiv="content-type" content="text/html; charset=ISO-8859-1" >
		<meta http-equiv="cache-control" content="no-transform">
		<link href="/base.css" rel="stylesheet" type="text/css">
		<link href="/spect.css" rel="stylesheet" type="text/css">
		<title>Downlink&nbsp;Spectrum</title>
		<script language="JavaScript" type="text/javascript" src="/base.js"></script>
		<script language="JavaScript" type="text/javascript" src="/config.js"></script>
		<script language="JavaScript" type="text/javascript" src="/monitor.js"></script>
		<script language="JavaScript" type="text/javascript" src="/objfactory.js"></script>
		<script language="JavaScript" type="text/javascript" src="/spect.js"></script>
	</head>
	<body onload="onloadInit();" onunload="stop_loading_spectrum();">
		<div style="outline: thick solid #808080;padding: 5px 2px 5px 2px;margin: 5px 2px 5px 2px; background-color: #ABABAB; width: 1000px;position: relative; overflow: hidden;">
			<div style="display: table;">
				<div style="display: table-row">
					<div style="display: table-cell;vertical-align: middle;"></div>
					<div style="display: table-cell;vertical-align: middle;"></div>
					<div style="display: table-cell; outline: thin solid #db5902">
						<table style="border-collapse: collapse;"><tbody><tr>
							<td class="stitle" style="min-width: 100px;" id="inSpectRefresh"></td>
							<td id="chainTitle" class="ttitle" style="width: 600px;text-align: center;">SPECTRUM</td>
							<td class="stitle" style="min-width: 100px;" id="spectTip"></td>
						</tr></tbody></table></div>
					<div style="display: table-cell;vertical-align: middle;"></div>
					<div style="display: table-cell;vertical-align: middle;"></div>
				</div>
				<div style="display: table-row">
					<div style="display: table-cell;width: 46px;vertical-align: middle;text-align: center;margin: 5px 5px 5px 5px;">
						<p class="stitlein">IN</p><p>(dBm)</p>
					</div>
					<div style="display: table-cell;width: 40px; position: relative;" id="inScale"></div>
					<div style="display: table-cell;height: 480px;width:801px;outline: thin solid #db5902;" id="contentbox" class="spectContentBox"></div>
					<div style="display: table-cell;width: 40px; position: relative;" id="outScale"></div>
					<div style="display: table-cell;width: 46px; vertical-align: middle;text-align: center;">
						<p class="stitleout">OUT</p><p>(dBm)</p>
					</div>
				</div>
				<div style="display: table-row">
					<div style="display: table-cell;"></div>
					<div style="display: table-cell;"></div>
					<div style="display: table-cell;height:20px; position: relative;" id="xScale"></div>
					<div style="display: table-cell;" id></div>
					<div style="display: table-cell;"></div>
				</div>
			</div>
			<div style="margin: 2px 10px 2px 10px; padding: 2px; outline: thin solid #db5902; position: relative; overflow: hidden;">
				<div id="spanStart"  style="display: inline-block;width: 19%;float: left; text-align: left;"></div>
				<div id="resBw"      style="display: inline-block;width: 12%; text-align: center;"></div>
				<div id="spanStep"   style="display: inline-block;width: 12%; text-align: center;"></div>
				<div id="avgCnt"     style="display: inline-block;width: 10%; text-align: center;"></div>
				<div id="signalChain" style="display: inline-block;width: 8%; text-align: right;"></div>
				<div id="ioSel" style="display: inline-block;width: 10%; text-align: right;"></div>
				<div id="zeroSpan"   style="display: inline-block;width: 8%; text-align: right;"></div>
				<div id="spanStop"   style="display: inline-block;width: 17%;float: right; text-align: right;"></div>
			</div>
		</div>
		<form id="spectrum_req" name="spectrum_req" action="/spect.zhtml" METHOD="POST" accept-charset="ISO-8859-1">
			<input type="hidden" id="spect_req" name="spect_req">
			<input type="hidden" id="confs_req" name="confs_req">
			<input type="hidden" id="freq_req" name="freq_req">
			<input type="hidden" id="fact_req" name="fact_req">
			<input type="hidden" id="spect_band" name="spect_band">
		</form>
	</body>
</html>
