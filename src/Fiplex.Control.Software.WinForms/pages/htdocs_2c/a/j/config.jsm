gn 1st ADJBW Filter to Band 14: "+boolToYN(t.firstADJisFirstNet)+"\n"),h+="\t\tADJBW ON:",i=0;i<r;i++)h+=n[i]+1+", ";for(0<r&&(h=h.substring(0,h.length-2)),h+="\n",f=0;f<2;f++){for(h+="\t\tADJBW Frequency Start-Stop "+a[f]+" (MHz): ",i=0;i<r;i++)h+=t.fstartHzAdjFilter[s][f][n[i]]/1e6+"-"+t.fstopHzAdjFilter[s][f][n[i]]/1e6+", ";0<r&&(h=h.substring(0,h.length-2)),h+="\n"}for(f=0;f<2;f++){for(h+="\t\tFilter Fine Gain "+a[f]+" (dB): ",i=0;i<r;i++)h+=t.fineGainFilter[1][s][f][n[i]]+", ";0<r&&(h=h.substring(0,h.length-2)),h+="\n"}for(f=0;f<2;f++){for(h+="\t\tFilter Squelch Enable "+a[f]+": ",i=0;i<r;i++)h+=boolToYN(t.sqChEnabled[1][s][f][n[i]])+", ";0<r&&(h=h.substring(0,h.length-2)),h+="\n"}for(f=0;f<2;f++){if(h+="\t\tFilter Squelch Threshold "+a[f]+" (dBm): ",!e.chBandEnabled[s]&&e.adjBandEnabled[s]&&t.squelchAdjBwMode[s])h+="Based on Narrow Band Filters";else{for(i=0;i<r;i++)h+=t.sqChThreshold[1][s][f][n[i]]+", ";0<r&&(h=h.substring(0,h.length-2))}h+="\n"}for(h+="\t\tC/N Threshold UL (dBm): ",i=0;i<r;i++)h+=t.cn_threshold_adj[s][i]+", ";if(0<r&&(h=h.substring(0,h.length-2)),h+="\n",!e.chBandEnabled[s]&&e.adjBandEnabled[s]&&t.squelchAdjBwMode[s]){h+="\tNarrow Band Filters for Squelch Detection of ADJBW\n";var o=t.CHNR;e.singleBandEnabled[s]&&(o*=2);for(var l=[],f=r=0;f<o;f++)t.filterEnabled[0][s][0][f]&&(l.push(f),r++);for(h+="\t\tFilter ON: ",f=0;f<r;f++)h+=l[f]+1+", ";for(0<r&&(h=h.substring(0,h.length-2)),h+="\n",f=0;f<2;f++){for(h+="\t\tFilter Frequency "+a[f]+" (MHz): ",i=0;i<r;i++)h+=t.freqHz[s][f][l[i]]/1e6+", ";0<r&&(h=h.substring(0,h.length-2)),h+="\n"}for(f=0;f<2;f++){for(h+="\t\tFilter Bandwidth "+a[f]+" (KHz): ",i=0;i<r;i++)h+=t.bwKHz[s][f][l[i]]+", ";0<r&&(h=h.substring(0,h.length-2)),h+="\n"}for(f=0;f<2;f++)if(h+="\t\tFilter Squelch Threshold "+a[f]+" (dBm): ",0==f)h+=t.sqChThreshold[0][s][f][0]+"\n";else{for(i=0;i<r;i++)h+=t.sqChThreshold[0][s][f][l[i]]+", ";0<r&&(h=h.substring(0,h.length-2)),h+="\n"}for(h+="\t\tAll filters with same squelch settings DL: "+boolToYN(t.allSameSquelch[s])+"\n",f=0;f<2;f++)h+="\t\tAll filters with same Bandwidth "+a[f]+": "+boolToYN(t.allChSameBW[s][f])+"\n";h+="\t\tC/N Threshold UL (dBm): "+t.cn_threshold_nb[s]+"\n"}}return h}function rfConfigAlarmToText(t,e){var s="";return s+="\tRF Alarm Settings\n",s+="\t\tReturn Loss Threshold (dB): "+t.retLossTh[e]+"\n",s+="\t\tMinimum TX Power for VSWR Detection (dBm): "+t.minPowerVSWR[e]+"\n",s+="\t\tReturn Loss Alarm Sensitivity (seconds): "+t.alarmNumSens[e]+"\n",s+="\t\tDonor Antenna Failure Timer Threshold (seconds): "+t.timeTxLowPowLow[e]+"\n"}function boolToYN(t){return t?"YES":"NO"}function agcModeText(t){return 0==t?"STABLE COVERAGE":"MAX. POWER"}function rfConfigBaseStationToText(t,e){var s="";return s+="\tBase Station:\n",s+="\t\tPower (dBm): "+t.base_station_power[e]+"\n",s+="\t\tSensitivity (dBm): "+t.base_station_sensitivity[e]+"\n"}