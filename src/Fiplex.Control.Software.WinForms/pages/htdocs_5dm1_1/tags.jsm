function Tags(){this.TAGLEN=30,this.tag="",this.parse=function(t){try{this.tag="";for(var i=0;i<t.length&&i<2*this.TAGLEN;i+=2){var r=t.substr(i,2),r=parseInt(r,16);isNaN(r)?this.tag+="&nbsp;":this.tag+=String.fromCharCode(r)}}catch(t){}},this.parseRawText=function(t){try{this.tag="";for(var i=0;i<t.length&&i<this.TAGLEN;i++){var r=t.charCodeAt(i);this.tag+=32<=r&&r<127?t[i]:" "}}catch(t){}},this.isEmpty=function(){for(var t=0;t<this.tag.length&&t<this.TAGLEN;t++)if(32!=this.tag.charCodeAt(t))return!1;return!0},this.render=function(){try{setTag(this.tag)}catch(t){}},this.getTag=function(){return this.tag},this.format=function(t){t=t.trim();for(var i=0;i<this.TAGLEN;++i)t+=" ";return t=t.slice(0,this.TAGLEN)}}