<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
	"http://www.w3.org/TR/html4/loose.dtd">
<html>
<!--<![-->
	<head>
		<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" >
		<meta http-equiv="content-type" content="text/html; charset=ISO-8859-1" >
		<meta http-equiv="cache-control" content="no-transform">
		<link id="cssfile" href="/base.css" rel="stylesheet" type="text/css">
		<script language="JavaScript" type="text/javascript" src="/base.js"></script>
		<script language="JavaScript" type="text/javascript" src="/objfactory.js"></script>
		<script language="JavaScript" type="text/javascript" src="/config.js"></script>
		<script language="JavaScript" type="text/javascript" src="/navi.js"></script>				
		<script language="JavaScript" type="text/javascript">
		function reloadData() {
		}
		function submitform() {
			document.getElementById("password_form").submit();
		}
		</script>
		<style type="text/css">
			table.passtable {
				border-collapse:collapse;
				text-align:center;
			}
			passtable.th {
				padding-right:10px;
			}
			input.passtable {
				text-align:left;
			}
		</style>
	</head>
	<body>
		<form id="password_form" name="password_form" action="/pass_close.html" METHOD="POST">
			<h1>WEB PASSWORD CHANGE</h1><br/>
			<table class="passtable"><tbody>
			<tr><th>CURRENT PASSWORD</th><td>&nbsp;&nbsp;</td>
				<td><input type="password" size="21" maxlength="20" id="pass_curr" name="pass_curr" class="passtable"></td>
			</tr><br/>
			<tr><th>NEW PASSWORD</th><td>&nbsp;&nbsp;</td>
				<td><input type="password" size="21" maxlength="20" id="pass_new" name="pass_new" class="passtable"></td>
			</tr><br/>
			<tr><th>CONFIRM NEW PASSWORD</th><td>&nbsp;&nbsp;</td>
				<td><input type="password" size="21" maxlength="20" id="pass_confirm" name="pass_confirm" class="passtable"></td>
			</tr><br/>
			</tbody></table>
		</form><br/><br/>
	</body>
</html>
