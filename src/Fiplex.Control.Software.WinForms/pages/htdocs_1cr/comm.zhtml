<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
	"http://www.w3.org/TR/html4/loose.dtd">
<html>
<!--<![-->
	<head>
		<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" >
		<meta http-equiv="content-type" content="text/html; charset=ISO-8859-1" >
		<meta http-equiv="cache-control" content="no-transform">
		<link href="/base.css" rel="stylesheet" type="text/css">
		<script language="JavaScript" type="text/javascript" src="/base.js"></script>
		<script language="JavaScript" type="text/javascript" src="/comm.js"></script>
		<style type="text/css">
			table.passtable {
				border-collapse:collapse;
				text-align:center;
			}
			passtable.th {
				padding-right:10px;
			}
			input.passtable {
				text-align:left;
			}
		</style>
	</head>
	<body onload="onloadInit();" onunload="onUnload();">
		<form id="comm_form" name="comm_form" action="/comm.zhtml" METHOD="POST">
			<input type="hidden" id="np_commfrm" name="np_commfrm" value="">
			<h1>SNMP COMMUNITIES</h1><br/>
			<table class="passtable"><tbody>
			<tr><th>READ-ONLY COMMUNITY</th><td>&nbsp;&nbsp;</td>
				<td><input type="text" size="21" maxlength="16" id="commro" name="commro" class="passtable"></td>
			</tr><br/>
			<tr><th>READ-WRITE COMMUNITY</th><td>&nbsp;&nbsp;</td>
				<td><input type="text" size="21" maxlength="16" id="commrw" name="commrw" class="passtable"></td>
			</tr><br/>
			<tr><th>MANAGER 1 TRAP COMMUNITY</th><td>&nbsp;&nbsp;</td>
				<td><input type="text" size="21" maxlength="16" id="commtr1" name="commtr1" class="passtable"></td>
			</tr><br/>
			<tr><th>MANAGER 2 TRAP COMMUNITY</th><td>&nbsp;&nbsp;</td>
				<td><input type="text" size="21" maxlength="16" id="commtr2" name="commtr2" class="passtable"></td>
			</tr><br/>
			<tr><th>MANAGER 1 TRAP PORT</th><td>&nbsp;&nbsp;</td>
				<td><input type="text" size="21" maxlength="16" id="portr1" name="portr1" class="passtable"></td>
			</tr><br/>
			<tr><th>MANAGER 2 TRAP PORT</th><td>&nbsp;&nbsp;</td>
				<td><input type="text" size="21" maxlength="16" id="portr2" name="portr2" class="passtable"></td>
			</tr><br/>
			</tbody></table>
		</form><br/><br/>
	</body>
</html>
