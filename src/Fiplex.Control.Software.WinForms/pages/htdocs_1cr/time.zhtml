<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
	"http://www.w3.org/TR/html4/loose.dtd">
<html>
<!--<![-->
	<head>
		<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" >
		<meta http-equiv="content-type" content="text/html; charset=ISO-8859-1" >
		<meta http-equiv="cache-control" content="no-transform">
		<link href="/base.css" rel="stylesheet" type="text/css">
		<script language="JavaScript" type="text/javascript" src="/base.js"></script>
		<script language="JavaScript" type="text/javascript" src="/time.js"></script>
		<script language="JavaScript" type="text/javascript" src="/ptime.js"></script>
		<title>Fiplex Control Software</title>
	</head>
	<body onload="initTime()">
		<form id="time_form" name="time_form" action="/time.zhtml" METHOD="POST">
			<input type="hidden" id="time_str" name="time_str">
			<h1>SUPERVISION&nbsp;SYSTEM&nbsp;TIME</h1><br/>
			<h2>Current&nbsp;Time:&nbsp;&nbsp;<div name="time" id="time"></div></h2><br/><br/><br/>
			<table class="iptable"><tbody>
			<tr><th>YEAR</th><td>&nbsp;&nbsp;&nbsp;&nbsp;</td>
				<td><input type="text" size="4" maxlength="4" id="year" name="year" class="iptable" onkeypress="return numbersOnly(event);" onpaste="return false;"></td>
			</tr><br/>
			<tr><th>MONTH</th><td>&nbsp;&nbsp;&nbsp;&nbsp;</td>
				<td><input type="text" size="4" maxlength="2" id="month" name="montb" class="iptable" onkeypress="return numbersOnly(event);" onpaste="return false;"></td>
			</tr><br/>
			<tr><th>DAY</th><td>&nbsp;&nbsp;&nbsp;&nbsp;</td>
				<td><input type="text" size="4" maxlength="2" id="day" name="day" class="iptable" onkeypress="return numbersOnly(event);" onpaste="return false;"></td>
			</tr><br/>
			<tr><th>HOUR</th><td>&nbsp;&nbsp;&nbsp;&nbsp;</td>
				<td><input type="text" size="4" maxlength="2" id="hours" name="hours" class="iptable" onkeypress="return numbersOnly(event);" onpaste="return false;"></td>
			</tr><br/>
			<tr><th>MINUTES</th><td>&nbsp;&nbsp;&nbsp;&nbsp;</td>
				<td><input type="text" size="4" maxlength="2" id="minutes" name="minutes" class="iptable" onkeypress="return numbersOnly(event);" onpaste="return false;"></td>
			</tr><br/>
			<tr><th>SECONDS</th><td>&nbsp;&nbsp;&nbsp;&nbsp;</td>
				<td><input type="text" size="4" maxlength="2" id="seconds" name="seconds" class="iptable" onkeypress="return numbersOnly(event);" onpaste="return false;"></td>
			</tr><br/>
			</tbody></table>
		</form>
		<form id="time_req_form" name="time_req_form" action="/time.zhtml" METHOD="POST">
			<input type="hidden" id="time_req" name="time_req">
		</form>
	</body>
</html>
